    "/v1/usages": {
      "post": {
        "description": "Records one usage event. If idempotency_key matches a previously accepted event, the original event is returned. A duplicate event ID is a conflict.",
        "tags": [
          "usages"
        ],
        "summary": "Create usage",
        "operationId": "createUsage",
        "requestBody": {
          "content": {
            "application/json": {
