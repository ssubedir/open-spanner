{
  "name": "@ssubedir/open-spanner",
  "version": "0.1.11",
  "description": "TypeScript and JavaScript SDK for Open Spanner.",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/ssubedir/open-spanner"
  },
  "bugs": {
    "url": "https://github.com/ssubedir/open-spanner/issues"
  },
  "homepage": "https://github.com/ssubedir/open-spanner#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stream": {
      "types": "./dist/stream/index.d.ts",
      "import": "./dist/stream/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi-ts -f openapi-ts.config.ts",
    "build": "node ../../scripts/remove-paths.mjs dist && tsc -p tsconfig.json",
    "pack:dry-run": "npm pack --dry-run",
    "publish:sdk": "npm publish --access public",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:stream": "tsx --test ../tests/typescript/stream_integration.test.ts"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.98.2",
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "^1.14.0"
  }
}
